[
{% for host in prometheus_render_postgresql_hosts %}
  {
    "targets": ["{{ hostvars[host].prometheus_target_address | default(hostvars[host].ansible_host | default(host)) }}:9187"],
    "labels": {
      "environment": "{{ hostvars[host].monitoring_environment }}",
      "cluster": "{{ hostvars[host].monitoring_cluster }}",
      "tier": "{{ hostvars[host].monitoring_tier }}",
      "instance": "{{ host }}",
      "service": "postgres_exporter"
    }
  }{% if not loop.last %},{% endif %}
{% endfor %}
]

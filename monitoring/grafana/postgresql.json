{
  "__inputs": [
    {"name": "DS_PROMETHEUS", "label": "Prometheus", "description": "", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus"}
  ],
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"min": 0, "max": 1}, "overrides": []},
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "name"},
      "targets": [{"expr": "pg_up{environment=~\"$environment\",cluster=~\"$cluster\"}", "legendFormat": "{{instance}}", "refId": "A"}],
      "title": "PostgreSQL members",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "sum(pg_stat_database_numbackends{environment=~\"$environment\",cluster=~\"$cluster\",datname!=\"\"})", "refId": "A"}],
      "title": "Active backends",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "sum(pg_database_size_bytes{environment=~\"$environment\",cluster=~\"$cluster\",datname=~\"$database\"})", "refId": "A"}],
      "title": "Database size",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "id": 4,
      "options": {"legend": {"calcs": [], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "sum by (environment, cluster, instance) (rate(pg_stat_database_xact_commit{environment=~\"$environment\",cluster=~\"$cluster\",datname=~\"$database\"}[5m]))", "legendFormat": "{{instance}} commits", "refId": "A"}, {"expr": "sum by (environment, cluster, instance) (rate(pg_stat_database_xact_rollback{environment=~\"$environment\",cluster=~\"$cluster\",datname=~\"$database\"}[5m]))", "legendFormat": "{{instance}} rollbacks", "refId": "B"}],
      "title": "Transactions",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "id": 5,
      "options": {"legend": {"calcs": [], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "sum by (environment, cluster, instance, mode) (pg_locks_count{environment=~\"$environment\",cluster=~\"$cluster\",datname=~\"$database\"})", "legendFormat": "{{instance}} / {{mode}}", "refId": "A"}],
      "title": "Locks",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "id": 6,
      "options": {"legend": {"calcs": [], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "pg_replication_lag_seconds{environment=~\"$environment\",cluster=~\"$cluster\"}", "legendFormat": "{{instance}} replay lag", "refId": "A"}, {"expr": "clamp_min(timestamp(pg_stat_wal_receiver_last_msg_receipt_time{environment=~\"$environment\",cluster=~\"$cluster\"}) - pg_stat_wal_receiver_last_msg_receipt_time{environment=~\"$environment\",cluster=~\"$cluster\"}, 0)", "legendFormat": "{{instance}} receiver message age at scrape", "refId": "B"}],
      "title": "Physical replication",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "Bps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "id": 7,
      "options": {"legend": {"calcs": [], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "rate(pg_stat_database_blks_read{environment=~\"$environment\",cluster=~\"$cluster\",datname=~\"$database\"}[5m]) * 8192", "legendFormat": "{{instance}} disk read", "refId": "A"}, {"expr": "rate(pg_stat_database_blks_hit{environment=~\"$environment\",cluster=~\"$cluster\",datname=~\"$database\"}[5m]) * 8192", "legendFormat": "{{instance}} cache hit", "refId": "B"}],
      "title": "Database block throughput",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "green"}, "min": 0, "max": 1}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 21},
      "id": 8,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "vertical", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "name"},
      "targets": [{"expr": "(1 - pg_replication_is_replica{environment=~\"$environment\",cluster=~\"$cluster\"}) == 1", "legendFormat": "{{environment}} / {{cluster}} / {{instance}}", "refId": "A"}],
      "title": "Current PostgreSQL primaries",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"color": "dark-gray", "index": 0, "text": "Replica"}, "1": {"color": "green", "index": 1, "text": "Primary"}}, "type": "value"}], "max": 1, "min": 0}, "overrides": []},
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 21},
      "id": 9,
      "options": {"alignValue": "left", "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "mergeValues": true, "rowHeight": 0.8, "showValue": "never", "tooltip": {"mode": "single", "sort": "none"}},
      "targets": [{"expr": "1 - pg_replication_is_replica{environment=~\"$environment\",cluster=~\"$cluster\"}", "legendFormat": "{{environment}} / {{cluster}} / {{instance}}", "refId": "A"}],
      "title": "PostgreSQL primary history",
      "type": "state-timeline"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["ton-indexer", "postgresql"],
  "templating": {
    "list": [
      {"current": {}, "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "definition": "label_values(pg_up, environment)", "includeAll": true, "label": "Environment", "multi": true, "name": "environment", "options": [], "query": {"query": "label_values(pg_up, environment)", "refId": "PrometheusVariableQueryEditor-VariableQuery"}, "refresh": 1, "type": "query"},
      {"current": {}, "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "definition": "label_values(pg_up{environment=~\"$environment\"}, cluster)", "includeAll": true, "label": "Cluster", "multi": true, "name": "cluster", "options": [], "query": {"query": "label_values(pg_up{environment=~\"$environment\"}, cluster)", "refId": "PrometheusVariableQueryEditor-VariableQuery"}, "refresh": 1, "type": "query"},
      {"current": {}, "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "definition": "label_values(pg_stat_database_numbackends{environment=~\"$environment\",cluster=~\"$cluster\",datname!~\"postgres|template0|template1\"}, datname)", "includeAll": true, "label": "Database", "multi": true, "name": "database", "options": [], "query": {"query": "label_values(pg_stat_database_numbackends{environment=~\"$environment\",cluster=~\"$cluster\",datname!~\"postgres|template0|template1\"}, datname)", "refId": "PrometheusVariableQueryEditor-VariableQuery"}, "refresh": 1, "type": "query"}
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "TON Indexer / PostgreSQL",
  "uid": "ton-indexer-postgresql",
  "version": 4
}

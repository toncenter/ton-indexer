{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red"}, {"color": "green", "value": 1}]}}, "overrides": []},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "sum(up{environment=~\"$environment\"})", "refId": "A"}],
      "title": "Exporters up",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "red", "value": 1}]}}, "overrides": []},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "sum(1 - up{environment=~\"$environment\"})", "refId": "A"}],
      "title": "Exporters down",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "max(ton_indexer_last_block_age_seconds{environment=~\"$environment\"})", "refId": "A"}],
      "title": "Maximum block age",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "max(ton_classifier_schedule_gap_blocks{environment=~\"$environment\"})", "refId": "A"}],
      "title": "Classifier scheduling gap",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "id": 5,
      "options": {"legend": {"calcs": [], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "100 - (avg by (environment, instance) (rate(node_cpu_seconds_total{environment=~\"$environment\",mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{environment}} / {{instance}}", "refId": "A"}],
      "title": "CPU usage",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "id": 6,
      "options": {"legend": {"calcs": [], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "100 * (1 - node_filesystem_avail_bytes{environment=~\"$environment\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{environment=~\"$environment\",fstype!~\"tmpfs|overlay\"})", "legendFormat": "{{environment}} / {{instance}} / {{mountpoint}}", "refId": "A"}],
      "title": "Filesystem usage",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "id": 7,
      "options": {"legend": {"calcs": [], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "ton_indexer_last_block_age_seconds{environment=~\"$environment\"}", "legendFormat": "{{target}}", "refId": "A"}, {"expr": "ton_indexer_leader_heartbeat_age_seconds{environment=~\"$environment\",tier=\"hot\"}", "legendFormat": "{{target}} leader heartbeat", "refId": "B"}],
      "title": "Pipeline freshness",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "id": 8,
      "options": {"legend": {"calcs": [], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "ton_logical_slot_retained_wal_bytes{environment=~\"$environment\"}", "legendFormat": "{{target}} retained", "refId": "A"}, {"expr": "ton_logical_subscription_unapplied_bytes{environment=~\"$environment\"}", "legendFormat": "{{target}} unapplied", "refId": "B"}],
      "title": "Logical replication backlog",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "green"}, "min": 0, "max": 1}, "overrides": []},
      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 21},
      "id": 9,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "name"},
      "targets": [{"expr": "(1 - pg_replication_is_replica{environment=~\"$environment\"}) == 1", "legendFormat": "PostgreSQL / {{environment}} / {{cluster}} / {{instance}}", "refId": "A"}, {"expr": "max by (environment, cluster, master_name, master_address) (redis_sentinel_master_status{environment=~\"$environment\",master_status=\"ok\"} == 1)", "legendFormat": "Kvrocks / {{environment}} / {{cluster}} / {{master_name}} / {{master_address}}", "refId": "B"}],
      "title": "Current cluster leaders",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"color": "dark-gray", "index": 0, "text": "Replica"}, "1": {"color": "green", "index": 1, "text": "Leader"}}, "type": "value"}], "max": 1, "min": 0}, "overrides": []},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 28},
      "id": 10,
      "options": {"alignValue": "left", "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "mergeValues": true, "rowHeight": 0.8, "showValue": "never", "tooltip": {"mode": "single", "sort": "none"}},
      "targets": [{"expr": "1 - pg_replication_is_replica{environment=~\"$environment\"}", "legendFormat": "PostgreSQL / {{environment}} / {{cluster}} / {{instance}}", "refId": "A"}, {"expr": "max by (environment, cluster, master_name, master_address) (redis_sentinel_master_status{environment=~\"$environment\",master_status=\"ok\"} == 1)", "legendFormat": "Kvrocks / {{environment}} / {{cluster}} / {{master_name}} / {{master_address}}", "refId": "B"}],
      "title": "Cluster leader history",
      "type": "state-timeline"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["ton-indexer", "monitoring"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(up, environment)",
        "includeAll": true,
        "label": "Environment",
        "multi": true,
        "name": "environment",
        "options": [],
        "query": {"query": "label_values(up, environment)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "refresh": 1,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "TON Indexer / Overview",
  "uid": "ton-indexer-overview",
  "version": 2
}

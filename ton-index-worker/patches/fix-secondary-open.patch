+ColumnFamilyData* ManifestTailer::DestroyCfAndCleanup(
+    const VersionEdit& edit) {
+  auto base_iter = manifest_base_versions_.find(edit.GetColumnFamily());
+  if (base_iter != manifest_base_versions_.end()) {
+    base_iter->second->Unref();
+    manifest_base_versions_.erase(base_iter);
+  }
+  return VersionEditHandlerPointInTime::DestroyCfAndCleanup(edit);
+}

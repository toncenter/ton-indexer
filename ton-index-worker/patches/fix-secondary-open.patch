+Version* ManifestTailer::GetManifestBaseVersion(ColumnFamilyData* cfd) {
+  auto base_iter = manifest_base_versions_.find(cfd->GetID());
+  if (base_iter != manifest_base_versions_.end()) {
+    return base_iter->second;
+  }
+
+  Version* dummy_version = cfd->dummy_versions();
+  assert(dummy_version);
+  Version* base_version = dummy_version->Next();
+  assert(base_version);
+  assert(base_version != dummy_version);
+  base_version->Ref();
+  manifest_base_versions_.emplace(cfd->GetID(), base_version);
+  return base_version;
+}

{
  "name": "ton-indexer-clion",

  "build": {
    "dockerfile": "../Dockerfile",
    "context": "..",
    "options": [
      "--tag",
      "ton-indexer-dev:clion"
    ]
  },

  "workspaceFolder": "/workspaces/ton-indexer",
  "remoteUser": "dev",

  "runArgs": [
    "--name=ton-indexer-clion-dev",
    "--network=docker_global",
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp=unconfined"
  ],

  "customizations": {
    "jetbrains": {
      "backend": "CLion"
    }
  },

  "postCreateCommand": "git --version && cmake --version && ninja --version && clang++-20 --version"
}

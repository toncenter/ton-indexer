{
  "name": "ton-indexer-goland",

  "build": {
    "dockerfile": "../Dockerfile",
    "context": "..",
    "options": [
      "--tag",
      "ton-indexer-dev:goland"
    ]
  },

  "workspaceFolder": "/workspaces/ton-indexer/ton-index-go",
  "remoteUser": "dev",

  "runArgs": [
    "--name=ton-indexer-goland-dev",
    "--network=docker_global",
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp=unconfined"
  ],

  "customizations": {
    "jetbrains": {
      "backend": "GoLand"
    }
  },

  "postCreateCommand": "cd /workspaces/ton-indexer/ton-index-go && go version && go env GOMOD"
}